% Modello AR(1) per i rendimenti LIN + Test di Ljung Box
y_lin = lin(2:end);
yrit_lin = lin(1:end-1); 
T = size(y_lin,1);
X = [ones(T,1) yrit_lin];
beta_lin = inv(X'*X)*X'*y_lin;
res_lin = y_lin - X*beta_lin;
h_lin = lbqtest(res_lin) 
