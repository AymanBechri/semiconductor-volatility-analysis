disp('************************************************************')
disp('Stima VaR')
disp('************************************************************')
pesi = [1/3, 1/3, 1/3];
alpha = 0.95;
W = 300;

% Approccio Univariato
rendimenti = [lin, toely, ssnlf];
corr_rend = corrcoef(rendimenti); 
sigma_t1 = [sigma_f_lin(1), sigma_f_toely(1), sigma_f_ssnlf(1)];
D = diag(sigma_t1);    
Sigma_cond = D * corr_rend * D;     
sigma2_p = pesi * Sigma_cond * pesi';
sigma_p = sqrt(sigma2_p);
z = norminv(alpha);        
VaR_univariato = W * z * (sigma_p/100);

% Calcolo VaR Univariato 
VaR_uni_usd = VaR_univariato; 
VaR_uni_perc = (VaR_uni_usd / W) * 100;

% Approccio Multivariato
corr_shock = corrcoef(E); 
sigma_t1_shock = [sigma_f_sh_lin(1), sigma_f_sh_toely(1), sigma_f_sh_ssnlf(1)];
D_shock = diag(sigma_t1_shock);
Sigma_cond_multi = D_shock * corr_shock * D_shock;
sigma2_p_multi = pesi * Sigma_cond_multi * pesi';
sigma_p_multi = sqrt(sigma2_p_multi);

% 5. Calcolo VaR Multivariato
VaR_multi_usd = W * z * (sigma_p_multi/100);
VaR_multi_perc = (VaR_multi_usd / W) * 100;

disp('************************************************************')
disp('Confronto VaR')
disp('************************************************************')
disp('Modello Univariato(AR-GARCH)')
disp('VaR_Dollari:')
disp(VaR_uni_usd)
disp('VaR_Percentuale:')
disp(VaR_uni_perc)

disp('Modello Multivariato (VAR-GARCH)')
disp('VaR_Dollari:') 
disp(VaR_multi_usd)
disp('VaR_Percentuale:')
disp(VaR_multi_perc)
