disp('************************************************************')
disp('Modello VAR e Ordine Cholesky ')
disp('************************************************************')
%IRF
% Ordine di Cholesky basato sulla catena di fornitura:
% Linde (LIN, materiali base) -> Tokyo Electron (TOELY, attrezzature) -> Samsung Electronics (SSNLF, prodotto finale)
y = [lin toely ssnlf];
n = size(y,2);   
p = 1;           
obs = size(y,1);

Y = y(p+1:end,:);
X = y(p:obs-1,:);
for i=1:p-1
    X = [X y(p-i:obs-i-1,:)];
end
X = [ones(obs-p,1) X];

T = obs-p;
A = (X'*X)^(-1)*X'*Y;
E = Y - X*A;
Sigma = E'*E/T;
A = A(2:n*p+1,:); 
A = [A'; eye((p-1)*n) zeros((p-1)*n,n)];

% orizzonte temporale
H = 16; 
J = [eye(n,n) zeros(n,n*(p-1))]; 
P = chol(Sigma)'; 
IRF = reshape(J*A^0*J'*P, n^2, 1); 

for i=1:H
    IRF = [IRF reshape(J*A^i*J'*P, n^2, 1)];
end
h_plot = 0:H;

figure('Name', 'Funzioni di Risposta all Impulso (IRF)', 'NumberTitle', 'off');

% Risposta di LIN allo shock di LIN
subplot(3,3,1)
plot(h_plot, IRF(1,:), 'red', 'LineWidth', 2);
title('Risp. LIN a Shock LIN')
ylabel('IRF LIN')
xlim([0 H])
yline(0)

% Risposta di TOELY allo shock di LIN 
subplot(3,3,4)
plot(h_plot, IRF(2,:), 'red', 'LineWidth', 2);
title('Risp. TOELY a Shock LIN')
ylabel('IRF TOELY')
xlim([0 H])
yline(0)

% Risposta di SSNLF allo shock di LIN
subplot(3,3,7)
plot(h_plot, IRF(3,:), 'red', 'LineWidth', 2);
title('Risp. SSNLF a Shock LIN')
ylabel('IRF SSNLF')
xlabel('Orizzonte (Settimane)')
xlim([0 H])
yline(0)

